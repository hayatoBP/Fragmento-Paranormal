<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="TOP_CENTER" spacing="20" prefWidth="900" prefHeight="560"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.fragmentoparanormal.controller.ArtefatosController"
      style="-fx-padding: 28; -fx-background-color: #1a1a2e;">

    <!-- ===== COLUNA ESQUERDA: listas ===== -->
    <VBox spacing="14" prefWidth="300" alignment="TOP_CENTER">

        <Label text="🔮  Artefatos"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
        <Label fx:id="lblSlots" text="Equipados: 0 / 2"
               style="-fx-font-size: 13px; -fx-text-fill: #2ecc71;"/>

        <!-- Não equipados -->
        <VBox spacing="6"
              style="-fx-background-color: #16213e; -fx-border-color: #9b59b6;
                     -fx-border-width: 1; -fx-border-radius: 4; -fx-padding: 10;">
            <Label text="No Inventário"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #bdc3c7;"/>
            <ListView fx:id="listaNoInventario" prefHeight="170"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
        </VBox>

        <!-- Equipados -->
        <VBox spacing="6"
              style="-fx-background-color: #16213e; -fx-border-color: #f1c40f;
                     -fx-border-width: 1; -fx-border-radius: 4; -fx-padding: 10;">
            <Label text="⚡ Equipados (máx 2)"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #f1c40f;"/>
            <ListView fx:id="listaEquipados" prefHeight="100"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Button text="← Voltar ao Inventário" prefWidth="240" onAction="#voltar"
                style="-fx-background-color: #555; -fx-text-fill: white; -fx-font-size: 13px;"/>
    </VBox>

    <!-- ===== COLUNA DIREITA: detalhes ===== -->
    <VBox spacing="12" prefWidth="540" alignment="TOP_LEFT"
          style="-fx-background-color: #16213e; -fx-border-color: #9b59b6;
                 -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;
                 -fx-padding: 20;">

        <Label fx:id="lblNome" text="Selecione um artefato"
               style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: #e0d0ff;"/>

        <Separator style="-fx-background-color: #9b59b6;"/>

        <Label fx:id="lblDescricao" text="" wrapText="true" prefWidth="500"
               style="-fx-font-size: 13px; -fx-text-fill: #bdc3c7;"/>

        <Label text="Bônus Passivos:" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
        <Label fx:id="lblBonuses" text="" wrapText="true" prefWidth="500"
               style="-fx-font-size: 13px; -fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Label fx:id="lblFeedback" text="" wrapText="true" prefWidth="500"
               style="-fx-font-size: 13px;"/>

        <HBox spacing="14">
            <Button fx:id="btnEquipar" text="🔮  Equipar" prefWidth="200"
                    disable="true" onAction="#equipar"
                    style="-fx-background-color: #9b59b6; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Button fx:id="btnDesequipar" text="✕  Desequipar" prefWidth="180"
                    disable="true" onAction="#desequipar"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                           -fx-font-size: 14px;"/>
        </HBox>
    </VBox>

</HBox>
