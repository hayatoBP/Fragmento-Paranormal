<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="900" prefHeight="620"
            fx:controller="com.mycompany.fragmentoparanormal.controller.MenuMissoesController"
            style="-fx-background-color: #0a0000;">

    <top>
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 28 0 14 0;
                     -fx-border-color: #8b0000; -fx-border-width: 0 0 1 0;">
            <Label text="MISSÕES"
                   style="-fx-font-size: 30px; -fx-font-weight: bold;
                          -fx-text-fill: #cc0000;"/>
            <Label fx:id="lblProgresso" text="Páginas do diário: 0/24"
                   style="-fx-font-size: 13px; -fx-text-fill: #555;
                          -fx-font-style: italic;"/>
        </VBox>
    </top>

    <center>
        <!-- Lista de missões com ícones de elemento -->
        <VBox alignment="CENTER" spacing="16"
              style="-fx-padding: 24 60;">
            <ListView fx:id="listaMissoes" prefHeight="280" prefWidth="700"
                      style="-fx-background-color: #1a0000;
                             -fx-border-color: #8b0000; -fx-border-width: 1;
                             -fx-border-radius: 4; -fx-background-radius: 4;"/>

            <!-- Boss Final — visível só quando desbloqueado -->
            <Button fx:id="btnBoss"
                    text="☠  ENFRENTAR O BOSS FINAL"
                    prefWidth="360" onAction="#irParaBoss"
                    style="-fx-background-color: #3d0000; -fx-text-fill: #ff4444;
                           -fx-font-size: 17px; -fx-font-weight: bold;
                           -fx-border-color: #cc0000; -fx-border-width: 2;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 10 0;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="18"
              style="-fx-padding: 18 0 28 0;
                     -fx-border-color: #8b0000; -fx-border-width: 1 0 0 0;
                     -fx-background-color: #0a0000;">
            <Button fx:id="btnComecar" text="▶  JOGAR MISSÃO" prefWidth="200"
                    onAction="#comecarMissao"
                    style="-fx-background-color: #8b0000; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 10 0;"/>
            <Button text="🛒  Loja da Ivete" prefWidth="180"
                    onAction="#abrirLoja"
                    style="-fx-background-color: #1a0000; -fx-text-fill: #cc4444;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-border-color: #8b0000; -fx-border-width: 1;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 10 0;"/>
            <Button text="Voltar" prefWidth="120" onAction="#voltar"
                    style="-fx-background-color: transparent; -fx-text-fill: #555;
                           -fx-border-color: #333; -fx-border-width: 1;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 10 0;"/>
        </HBox>
    </bottom>
</BorderPane>
