<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!--
    Tela de Diálogo:
    - AnchorPane raiz cobre toda a janela
    - imgCenario ancorado nos 4 cantos = fundo de tela inteira
    - imgProtagonista ancorado à esquerda/baixo
    - imgOrdem ancorado à direita/baixo
    - Caixa de fala ancorada na base
-->
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1024" prefHeight="700"
            fx:controller="com.mycompany.fragmentoparanormal.controller.DialogoController"
            style="-fx-background-color: #000;">

    <!-- Fundo preto puro — sem cenário -->

    <!-- PERSONAGEM PROTAGONISTA (esquerda, base da tela) -->
    <ImageView fx:id="imgProtagonista"
               fitWidth="300" fitHeight="460"
               preserveRatio="true"
               AnchorPane.leftAnchor="40"
               AnchorPane.bottomAnchor="140"/>

    <!-- PERSONAGEM ORDEM / NPC (direita, base da tela) -->
    <ImageView fx:id="imgOrdem"
               fitWidth="300" fitHeight="460"
               preserveRatio="true"
               AnchorPane.rightAnchor="40"
               AnchorPane.bottomAnchor="140"/>

    <!-- CAIXA DE DIÁLOGO (base da tela) -->
    <VBox spacing="10"
          style="-fx-padding: 18 40 20 40;
                 -fx-background-color: rgba(0,0,0,0.90);
                 -fx-border-color: #8b0000; -fx-border-width: 2 0 0 0;"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <Label fx:id="lblNome"
               style="-fx-text-fill: #cc0000; -fx-font-size: 17px;
                      -fx-font-weight: bold;"/>

        <Label fx:id="lblFala" wrapText="true"
               style="-fx-text-fill: #f0f0f0; -fx-font-size: 15px;"
               maxWidth="940"/>

        <HBox spacing="16" alignment="CENTER_RIGHT">
            <Button text="⏭  Pular Diálogo" onAction="#pularDialogo"
                    style="-fx-background-color: transparent; -fx-text-fill: #555;
                           -fx-font-size: 12px; -fx-cursor: hand;"/>
            <Button text="Próximo  ▶" onAction="#proximoDialogo"
                    style="-fx-background-color: #8b0000; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 8 24;"/>
        </HBox>
    </VBox>

</AnchorPane>
