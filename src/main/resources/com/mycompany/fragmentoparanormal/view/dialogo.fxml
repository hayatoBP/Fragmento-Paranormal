<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.fragmentoparanormal.controller.DialogoController">

    <center>
        <HBox alignment="CENTER" spacing="80">

            <ImageView fx:id="imgProtagonista"
                       fitWidth="250"
                       fitHeight="350"
                       preserveRatio="true"/>

            <ImageView fx:id="imgCenario"
                       fitWidth="450"
                       fitHeight="300"
                       preserveRatio="true"/>

        </HBox>
    </center>

    <bottom>
        <VBox spacing="10"
              style="-fx-padding: 20; -fx-background-color: #111;">

            <Label fx:id="lblNome"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label fx:id="lblFala"
                   wrapText="true"
                   style="-fx-text-fill: white; -fx-font-size: 16px;"/>

            <Button text="Próximo"
                    onAction="#proximoDialogo"/>

        </VBox>
    </bottom>

</BorderPane>
