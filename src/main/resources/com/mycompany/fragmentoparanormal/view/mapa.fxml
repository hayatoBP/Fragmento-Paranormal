<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           prefWidth="1024" prefHeight="700"
           fx:controller="com.mycompany.fragmentoparanormal.controller.MapaController"
           style="-fx-background-color: #000;">

    <!-- Cenário da missão ao fundo, escurecido -->
    <ImageView fx:id="imgFundoMapa" fitWidth="1024" fitHeight="700" preserveRatio="false"/>
    <VBox style="-fx-background-color: rgba(0,0,0,0.72);"/>

    <BorderPane>
        <!-- Cabeçalho -->
        <top>
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 18 0 10 0;
                         -fx-border-color: #8b0000; -fx-border-width: 0 0 1 0;
                         -fx-background-color: rgba(0,0,0,0.6);">
                <HBox alignment="CENTER" spacing="10">
                    <ImageView fx:id="imgElementoIcone" fitWidth="28" fitHeight="28" preserveRatio="true"/>
                    <Label fx:id="lblTituloMissao" text="Missão"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: #cc0000;"/>
                </HBox>
                <Label fx:id="lblProgresso" text="0 / 6 páginas encontradas"
                       style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            </VBox>
        </top>

        <!-- Área do mapa — canvas gerado pelo controller -->
        <center>
            <StackPane fx:id="painelMapa" style="-fx-padding: 20 40;">
                <!-- O mapa visual é gerado programaticamente pelo MapaController -->
                <!-- Conteúdo dinâmico: nós, corredores, ícone do jogador -->
            </StackPane>
        </center>

        <!-- Painel de info do local selecionado (base) -->
        <bottom>
            <VBox fx:id="painelInfo" spacing="6" visible="false" managed="false"
                  style="-fx-background-color: rgba(0,0,0,0.88);
                         -fx-border-color: #8b0000; -fx-border-width: 1 0 0 0;
                         -fx-padding: 14 40;">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblNomeLocal" text=""
                               style="-fx-font-size: 17px; -fx-font-weight: bold;
                                      -fx-text-fill: #cc0000;"/>
                        <Label fx:id="lblDescricaoLocal" text="" wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #ccc;"
                               maxWidth="700"/>
                        <Label fx:id="lblStatusPagina" text=""
                               style="-fx-font-size: 12px; -fx-text-fill: #888;
                                      -fx-font-style: italic;"/>
                    </VBox>
                    <Button fx:id="btnAvancarLocal" text="Ir para este local ▶"
                            onAction="#avancarParaLocal"
                            style="-fx-background-color: #8b0000; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-border-radius: 4; -fx-background-radius: 4;
                                   -fx-cursor: hand; -fx-padding: 10 24;"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>

    <!-- Botão voltar (canto superior esquerdo) -->
    <StackPane alignment="TOP_LEFT" style="-fx-padding: 14 0 0 20;">
        <Button text="← Voltar" onAction="#voltarParaMissao"
                style="-fx-background-color: transparent; -fx-text-fill: #555;
                       -fx-border-color: #333; -fx-border-width: 1;
                       -fx-border-radius: 4; -fx-background-radius: 4;
                       -fx-cursor: hand; -fx-padding: 6 16;"/>
    </StackPane>

</StackPane>
