<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.fragmentoparanormal.controller.LojaController"
      prefWidth="800" prefHeight="600" spacing="0"
      style="-fx-background-color: linear-gradient(to bottom, #0d0d1a, #1a0a2e);">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: rgba(0,0,0,0.5);
                 -fx-border-color: #6c3483; -fx-border-width: 0 0 1 0;
                 -fx-padding: 14 24;">
        <Label text="🛒  Loja da Ivete"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #d4a0ff;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblDinheiro"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #f0c040;"/>
    </HBox>

    <!-- Subtítulo -->
    <Label text="Escolha um item para comprar. Cada item pode ser comprado apenas uma vez."
           style="-fx-font-size: 12px; -fx-text-fill: #8060a0; -fx-padding: 8 24 4 24;"/>

    <!-- Itens -->
    <HBox fx:id="painelItens" alignment="CENTER" spacing="20"
          style="-fx-padding: 20 30;" VBox.vgrow="ALWAYS"/>

    <!-- Mensagem de feedback -->
    <Label fx:id="lblMensagem" wrapText="true" textAlignment="CENTER"
           style="-fx-font-size: 13px; -fx-text-fill: #a080c0;
                  -fx-font-style: italic; -fx-padding: 4 24;"
           maxWidth="720"/>

    <!-- Rodapé -->
    <HBox alignment="CENTER"
          style="-fx-background-color: rgba(0,0,0,0.4);
                 -fx-border-color: #6c3483; -fx-border-width: 1 0 0 0;
                 -fx-padding: 14 24;">
        <Button text="← Voltar" onAction="#voltar"
                style="-fx-background-color: #2a1a3a; -fx-text-fill: #c0a0e0;
                       -fx-font-size: 13px; -fx-padding: 8 24;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
    </HBox>
</VBox>
