<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           prefWidth="900" prefHeight="640"
           fx:controller="com.mycompany.fragmentoparanormal.controller.LojaController"
           style="-fx-background-color: #0a0000;">

    <!-- ═══════════════ CENÁRIO DE FUNDO DA LOJA ═══════════════ -->
    <ImageView fitWidth="900" fitHeight="640" preserveRatio="false" opacity="0.55">
        <image><Image url="@../images/ordem/loja_ivete_fundo.png"/></image>
    </ImageView>

    <!-- ═══════════════ TELA DE BOAS-VINDAS DA IVETE ═══════════════ -->
    <VBox fx:id="painelIvete" alignment="CENTER" spacing="0"
          style="-fx-background-color: transparent;">

        <!-- Ivete centralizada -->
        <StackPane alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
            <ImageView fitWidth="420" fitHeight="480" preserveRatio="true">
                <image><Image url="@../images/ordem/ivete.png"/></image>
            </ImageView>
        </StackPane>

        <!-- Fala da Ivete -->
        <VBox spacing="10"
              style="-fx-background-color: rgba(0,0,0,0.92);
                     -fx-border-color: #8b0000; -fx-border-width: 2 0 0 0;
                     -fx-padding: 20 60 28 60;">
            <Label text="IVETE"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;
                          -fx-text-fill: #cc0000;"/>
            <Label text="Bem-vindo à minha loja, agente. Não tenho tempo a perder —\ne você também não. Veja o que tenho e escolha com cuidado.\nVocê só pode levar cada item uma vez."
                   wrapText="true"
                   style="-fx-font-size: 14px; -fx-text-fill: #eee;"/>
            <Button text="Ver Itens  ▶" onAction="#mostrarItens"
                    style="-fx-background-color: #8b0000; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 8 32;"
                    alignment="CENTER_RIGHT"/>
        </VBox>
    </VBox>

    <!-- ═══════════════ TELA DE ITENS ═══════════════ -->
    <VBox fx:id="painelItens" spacing="0" visible="false" managed="false"
          style="-fx-background-color: transparent;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1a0000;
                     -fx-border-color: #8b0000; -fx-border-width: 0 0 1 0;
                     -fx-padding: 14 24;">
            <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                <image><Image url="@../images/ordem/ivete.png"/></image>
            </ImageView>
            <Label text="Loja da Ivete"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #cc0000;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDinheiro"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;
                          -fx-text-fill: #ffcc00;"/>
        </HBox>

        <Label text="Cada item pode ser comprado apenas uma vez."
               style="-fx-font-size: 12px; -fx-text-fill: #555;
                      -fx-padding: 8 24 4 24;"/>

        <!-- Itens -->
        <HBox fx:id="painelItensConteudo" alignment="CENTER" spacing="20"
              style="-fx-padding: 20 30;" VBox.vgrow="ALWAYS"/>

        <Label fx:id="lblMensagem" wrapText="true" textAlignment="CENTER"
               style="-fx-font-size: 13px; -fx-text-fill: #cc4444;
                      -fx-font-style: italic; -fx-padding: 4 24;"
               maxWidth="820"/>

        <!-- Rodapé -->
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a0000;
                     -fx-border-color: #8b0000; -fx-border-width: 1 0 0 0;
                     -fx-padding: 14 24;">
            <Button text="← Voltar" onAction="#voltar"
                    style="-fx-background-color: transparent; -fx-text-fill: #888;
                           -fx-border-color: #555; -fx-border-width: 1;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 8 24;"/>
        </HBox>
    </VBox>
</StackPane>
