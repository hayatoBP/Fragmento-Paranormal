<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.fragmentoparanormal.controller.CombateController"
            style="-fx-background-color: #1a1a2e;">

    <!-- ── TOPO: status ── -->
    <top>
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 12; -fx-background-color: #16213e; -fx-border-color: #333; -fx-border-width: 0 0 1 0;">
            <Label fx:id="lblNomeInimigo" text="Inimigo"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e0d0ff;"/>
            <HBox alignment="CENTER" spacing="30">
                <Label fx:id="lblVidaJogador" text="Vida: 100/100"
                       style="-fx-font-size: 14px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                <Label fx:id="lblPEJogador" text="PE: 30/30"
                       style="-fx-font-size: 14px; -fx-text-fill: #3498db; -fx-font-weight: bold;"/>
                <Label fx:id="lblVidaInimigo" text="Vida: 50"
                       style="-fx-font-size: 14px; -fx-text-fill: #8e44ad; -fx-font-weight: bold;"/>
                <Label fx:id="lblElementoInimigo" text="Elemento: ?"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdc3c7;"/>
                <Label fx:id="lblAmaldicao" text="" visible="false"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── CENTRO: imagens + log ── -->
    <center>
        <VBox alignment="CENTER" spacing="12" style="-fx-padding: 16;">
            <HBox alignment="CENTER" spacing="60">
                <ImageView fx:id="imgJogador" fitWidth="160" fitHeight="200" preserveRatio="true"/>
                <Label text="VS" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ecf0f1;"/>
                <ImageView fx:id="imgInimigo" fitWidth="160" fitHeight="200" preserveRatio="true"/>
            </HBox>
            <Label fx:id="lblEfetividade" text=""
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
            <Label fx:id="lblEventos" text="O combate começa!"
                   wrapText="true" maxWidth="700"
                   style="-fx-font-size: 14px; -fx-padding: 0 30; -fx-text-fill: #ecf0f1;"/>
        </VBox>
    </center>

    <!-- ── BAIXO: botões ── -->
    <bottom>
        <VBox spacing="8" alignment="CENTER" style="-fx-padding: 12; -fx-background-color: #16213e; -fx-border-color: #333; -fx-border-width: 1 0 0 0;">

            <!-- Linha 1: botão ATACAR (abre o submenu) + Inventário + Fugir + Continuar -->
            <HBox fx:id="painelPrincipal" alignment="CENTER" spacing="12">
                <Button fx:id="btnAtacar" text="⚔  Atacar" prefWidth="130" onAction="#mostrarMenuAtaque"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Button text="🎒  Inventário" prefWidth="130" onAction="#abrirInventario"
                        style="-fx-background-color: #6c3483; -fx-text-fill: white; -fx-font-size: 14px;"/>
                <Button fx:id="btnFugir" text="🏃  Fugir" prefWidth="130" onAction="#fugir"
                        style="-fx-background-color: #555; -fx-text-fill: #e74c3c; -fx-font-size: 14px;"/>
                <Button fx:id="btnVoltarMissao" text="✔  Continuar" prefWidth="130" onAction="#voltarMissao"
                        visible="false"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Linha 2: submenu de ataque (visível só após clicar Atacar) -->
            <HBox fx:id="painelMenuAtaque" alignment="CENTER" spacing="10" visible="false" managed="false">
                <Label text="▶" style="-fx-text-fill: #f39c12; -fx-font-size: 13px;"/>

                <!-- Ataque com Arma -->
                <Button fx:id="btnAtaqueArma" text="🗡  Arma" prefWidth="140" onAction="#atacarComArma"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 13px;"/>

                <!-- Ataque Especial -->
                <Button fx:id="btnAtaqueEspecial" text="💥  Especial" prefWidth="140" onAction="#atacarEspecial"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 13px;"/>

                <!-- Ritual -->
                <Button fx:id="btnRitual" text="☽  Ritual" prefWidth="140" onAction="#usarRitual"
                        style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-size: 13px;"/>

                <!-- Amaldiçoar Arma (visível apenas para Combatente nível 5+) -->
                <Button fx:id="btnAmaldicoar" text="🔥  Amaldiçoar" prefWidth="140"
                        visible="false" managed="false" onAction="#amaldicoarArma"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 13px;"/>

                <!-- Cancelar -->
                <Button text="✕" prefWidth="50" onAction="#fecharMenuAtaque"
                        style="-fx-background-color: #444; -fx-text-fill: #ccc; -fx-font-size: 13px;"/>
            </HBox>

            <!-- Dicas do submenu -->
            <Label fx:id="lblDicaAtaque" text="" wrapText="true"
                   style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-padding: 0 20;"/>
        </VBox>
    </bottom>

</BorderPane>
