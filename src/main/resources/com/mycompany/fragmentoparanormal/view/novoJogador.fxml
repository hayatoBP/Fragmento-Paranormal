<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER" spacing="40" prefWidth="900" prefHeight="620"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.fragmentoparanormal.controller.NovoJogadorController"
      style="-fx-background-color: #0a0000; -fx-padding: 40;">

    <!-- Formulário -->
    <VBox spacing="14" alignment="CENTER_LEFT" prefWidth="320">
        <Label text="NOVO AGENTE"
               style="-fx-font-size: 26px; -fx-font-weight: bold;
                      -fx-text-fill: #cc0000;"/>
        <Label text="Nome:" style="-fx-text-fill: #aaa; -fx-font-size: 13px;"/>
        <TextField fx:id="txtNome" promptText="Nome do agente" prefWidth="260"
                   style="-fx-background-color: #1a0000; -fx-text-fill: white;
                          -fx-border-color: #8b0000; -fx-border-width: 1;
                          -fx-border-radius: 4; -fx-background-radius: 4;
                          -fx-prompt-text-fill: #555; -fx-font-size: 13px;"/>
        <Label text="Classe:" style="-fx-text-fill: #aaa; -fx-font-size: 13px;"/>
        <ChoiceBox fx:id="choiceClasse" prefWidth="260"
                   style="-fx-background-color: #1a0000; -fx-mark-color: #cc0000;"/>
        <Label text="Gênero:" style="-fx-text-fill: #aaa; -fx-font-size: 13px;"/>
        <ChoiceBox fx:id="choiceGenero" prefWidth="260"
                   style="-fx-background-color: #1a0000; -fx-mark-color: #cc0000;"/>
        <Label text="Elemento:" style="-fx-text-fill: #aaa; -fx-font-size: 13px;"/>
        <ChoiceBox fx:id="choiceElemento" prefWidth="260"
                   style="-fx-background-color: #1a0000; -fx-mark-color: #cc0000;"/>
        <Label fx:id="lblErro" style="-fx-text-fill: #ff4444; -fx-font-size: 12px;"/>
        <HBox spacing="12">
            <Button text="CONFIRMAR" onAction="#criarJogador"
                    style="-fx-background-color: #8b0000; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 8 20;"/>
            <Button text="Voltar" onAction="#voltar"
                    style="-fx-background-color: #1a0000; -fx-text-fill: #888;
                           -fx-border-color: #333; -fx-border-width: 1;
                           -fx-border-radius: 4; -fx-background-radius: 4;
                           -fx-cursor: hand; -fx-padding: 8 20;"/>
        </HBox>
    </VBox>

    <!-- Preview personagem -->
    <VBox alignment="CENTER" spacing="14" prefWidth="380">
        <Label text="APARÊNCIA"
               style="-fx-font-size: 16px; -fx-font-weight: bold;
                      -fx-text-fill: #cc0000;"/>
        <!-- Borda vermelha ao redor da imagem -->
        <StackPane style="-fx-border-color: #8b0000; -fx-border-width: 2;
                          -fx-background-color: #1a0000; -fx-padding: 10;">
            <ImageView fx:id="imgPersonagem" fitWidth="280" fitHeight="380" preserveRatio="true"/>
        </StackPane>
        <Label fx:id="lblNomePersonagem" text=""
               style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-font-style: italic;"/>
    </VBox>

</HBox>
