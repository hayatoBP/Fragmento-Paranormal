<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER" spacing="40" prefWidth="800" prefHeight="600"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.fragmentoparanormal.controller.NovoJogadorController">

    <VBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Novo Agente" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
        <Label text="Nome:"/>
        <TextField fx:id="txtNome" promptText="Digite o nome do agente" prefWidth="220"/>
        <Label text="Classe:"/>
        <ChoiceBox fx:id="choiceClasse" prefWidth="220"/>
        <Label text="Gênero:"/>
        <ChoiceBox fx:id="choiceGenero" prefWidth="220"/>
        <Label text="Elemento:"/>
        <ChoiceBox fx:id="choiceElemento" prefWidth="220"/>
        <Label fx:id="lblErro" style="-fx-text-fill: red;"/>
        <HBox spacing="10">
            <Button text="Confirmar" onAction="#criarJogador"/>
            <Button text="Voltar" onAction="#voltar"/>
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10">
        <Label text="Aparência"/>
        <ImageView fx:id="imgPersonagem" fitWidth="220" fitHeight="300" preserveRatio="true"/>
    </VBox>

</HBox>
